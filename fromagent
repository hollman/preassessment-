# --- 2. Logic Functions ---
def get_level(percent):
    if percent < 35: return {"text": "Sub-Clinical / Low", "color": "green"}
    if percent < 65: return {"text": "Moderate Traits", "color": "orange"}
    return {"text": "High Likelihood", "color": "red"}

def generate_profile(scores):
    analysis = []
    # High Profiles
    if scores['asdModern']['percent'] >= 65 and scores['asdClassic']['percent'] < 50:
        analysis.append("<b>High-Masking Autistic Profile:</b> Your high score in Modern criteria combined with a lower score in Classic criteria strongly suggests 'high-masking' autism. You likely experience intense autistic traits internally but actively suppress them.")
    elif scores['asdClassic']['percent'] >= 65 and scores['asdModern']['percent'] >= 65:
        analysis.append("<b>Classic & Internalized Autistic Profile:</b> You scored high in both traditional and modern metrics, indicating a robust autistic neurotype that affects both external social navigation and internal processing.")
    if scores['adhd']['percent'] >= 65:
        analysis.append("<b>Prominent ADHD Profile:</b> Your responses heavily map to the traditional definition of ADHD (executive functioning, attention regulation). If paired with Autism scores, you may experience 'AuDHD' internal friction.")
    if scores['asdAsq']['percent'] >= 65 and scores['asdClassic']['percent'] < 50 and scores['asdModern']['percent'] < 50:
        analysis.append("<b>Systemizing Cognitive Style:</b> You possess a brain heavily wired for systemizing, pattern recognition, and detailed observation without the distress criteria, suggesting a non-clinical neurodivergent cognitive style.")
    
    # Low Profiles
    if scores['asdModern']['percent'] < 35:
        analysis.append("<b>Low Internalized Autistic Traits:</b> You do not report significant levels of masking, burnout, or demand avoidance.")
    if scores['asdClassic']['percent'] < 35:
        analysis.append("<b>Low Classic Autistic Traits:</b> You do not report significant struggles with traditional autistic markers.")
    if scores['adhd']['percent'] < 35:
        analysis.append("<b>Low ADHD Traits:</b> Your attention regulation and executive functioning appear typical.")
    if scores['asdAsq']['percent'] < 35:
        analysis.append("<b>Low Systemizing Traits:</b> Your cognitive style does not lean heavily toward rigid pattern recognition.")

    if not analysis:
        analysis.append("<b>Moderate/Mixed Profile:</b> Your scores fall entirely in the moderate range. Traits do not strongly cluster into a specific dominant profile.")
        
    return analysis

def clinical_guidance(scores):
    is_high = any(s['percent'] >= 65 for s in scores.values())
    is_mod = any(s['percent'] >= 35 for s in scores.values())
    if is_high:
        return "<b>Clinical Assessment is Strongly Indicated.</b> High scores map to established clinical definitions. If these traits cause chronic burnout or distress, a medical assessment can open doors to accommodations. If you experience no impairment, you may just possess a valid divergent neurotype."
    elif is_mod:
        return "<b>Assessment may be beneficial depending on distress levels.</b> You exhibit moderate traits. Assessment is warranted if these traits represent a change in functioning or cause friction in daily life."
    return "<b>Clinical Assessment is Not Currently Indicated.</b> Your responses do not cluster into recognized diagnostic criteria."

