for i, q in enumerate(questions):
    radio = widgets.RadioButtons(options=options, value=0, layout={'width': 'max-content'})
    answers_widgets[q['id']] = radio
    form_items.append(widgets.VBox([
        widgets.HTML(value=f"<p><b>{i+1}. {q['text']}</b></p>"),
        radio,
        widgets.HTML(value="<br/>")
    ]))

ui_form = widgets.VBox(form_items)
submit_btn = widgets.Button(description="Calculate Results", button_style="primary", layout={'width': '300px', 'height': '50px'})
output_area = widgets.Output()

def on_submit(b):
    with output_area:
        clear_output(wait=True)
        scores = {'adhd': 0, 'asdClassic': 0, 'asdModern': 0, 'asdAsq': 0}
        max_scores = {'adhd': 0, 'asdClassic': 0, 'asdModern': 0, 'asdAsq': 0}
        
        for q in questions:
            max_scores[q['category']] += 4
            scores[q['category']] += answers_widgets[q['id']].value
            
        formatted = {}
        for cat in scores:
            percent = int((scores[cat] / max_scores[cat]) * 100)
            formatted[cat] = {'score': scores[cat], 'percent': percent, 'level': get_level(percent)}

        html_result = "<h2>Assessment Results</h2><hr/><h3>Category Scores</h3><ul>"
        categories_map = {
            'adhd': 'ADHD Traits (Traditional)',
            'asdClassic': 'Autism (Classic DSM-5)',
            'asdModern': 'Autism (Modern/Internal)',
            'asdAsq': 'Autism Quotient (ASQ)'
        }
        
        for cat, label in categories_map.items():
            data = formatted[cat]
            html_result += f"<li><b>{label}:</b> {data['percent']}% - <span style='color:{data['level']['color']}'><b>{data['level']['text']}</b></span></li>"
            
        html_result += "</ul><hr/><h3>Your Trait Profile</h3><ul>"
        for profile in generate_profile(formatted):
            html_result += f"<li>{profile}</li><br/>"
            
        html_result += "</ul><hr/><h3>Clinical Assessment Guidance</h3>"
        html_result += f"<p>{clinical_guidance(formatted)}</p>"
        
        display(HTML(html_result))

submit_btn.on_click(on_submit)
display(ui_form, submit_btn, output_area)